# Install to /etc/claude-remote-api.env, owned by pigri, mode 0600.
# Required: the bearer token clients must send as `Authorization: Bearer <token>`.
CLAUDE_REMOTE_API_TOKEN=replace-with-a-long-random-token

# Optional overrides:
# Bind address (default :8080). Prefer binding to localhost behind a TLS
# reverse proxy / tunnel, since the bearer token travels in the header.
#CLAUDE_REMOTE_API_ADDR=127.0.0.1:8080

# Absolute path to the claude binary (robust regardless of PATH).
#CLAUDE_BIN=/home/pigri/.local/bin/claude

# Session name prefix (default pigri-dev-remote).
#CLAUDE_REMOTE_SESSION_PREFIX=pigri-dev-remote
