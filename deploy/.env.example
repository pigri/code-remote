# Copy to .env (gitignored) and fill in. The .env holds secrets + the private
# domain; only this example is committed.
#   Load:  set -a; . ./.env; set +a     (or systemd EnvironmentFile=.env)

# API — bound to localhost; Synapse is its only client.
CLAUDE_REMOTE_API_TOKEN=replace-with-a-long-random-token
CLAUDE_REMOTE_API_ADDR=127.0.0.1:9000
# Absolute paths — systemd's PATH doesn't include ~/.local/bin.
CLAUDE_BIN=/home/youruser/.local/bin/claude
SCREEN_BIN=/usr/bin/screen

# ngrok edge -> Synapse WAF (:8080). Authtoken is also in ~/.config/ngrok/ngrok.yml.
NGROK_AUTHTOKEN=replace-with-your-ngrok-authtoken
NGROK_DOMAIN=your-domain.ngrok.dev
NGROK_UPSTREAM=http://localhost:8080
